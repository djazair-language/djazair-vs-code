{
  "Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:args}):",
      "\t${3:// body}",
      "end"
    ],
    "description": "إنشاء دالة جديدة"
  },
  
  "Arrow Function": {
    "prefix": "af",
    "body": [
      "fn(${1:args}) => ${2:expression}"
    ],
    "description": "دالة سهمية"
  },

  "Class": {
    "prefix": "class",
    "body": [
      "class ${1:ClassName}:",
      "\tinit(${2:args}):",
      "\t\tself.${3:property} = ${4:value};",
      "\tend",
      "",
      "\t${5:method}(${6:args}):",
      "\t\t${7:// method body}",
      "\tend",
      "end"
    ],
    "description": "إنشاء صنف جديد"
  },

  "If Statement": {
    "prefix": "if",
    "body": [
      "if ${1:condition}:",
      "\t${2:// code}",
      "end"
    ],
    "description": "جملة if بسيطة"
  },

  "If Else": {
    "prefix": "ife",
    "body": [
      "if ${1:condition}:",
      "\t${2:// code}",
      "else:",
      "\t${3:// code}",
      "end"
    ],
    "description": "if else"
  },

  "If Elif Else": {
    "prefix": "ifel",
    "body": [
      "if ${1:condition}:",
      "\t${2:// code}",
      "elif ${3:condition}:",
      "\t${4:// code}",
      "else:",
      "\t${5:// code}",
      "end"
    ],
    "description": "if elif else كامل"
  },

  "Match Case": {
    "prefix": "match",
    "body": [
      "match ${1:value}:",
      "\tcase ${2:pattern1}:",
      "\t\t${3:// code}",
      "\tcase ${4:pattern2}:",
      "\t\t${5:// code}",
      "\tdefault:",
      "\t\t${6:// default code}",
      "end"
    ],
    "description": "جملة match case"
  },

  "For Loop": {
    "prefix": "for",
    "body": [
      "for ${1:item} in ${2:iterable}:",
      "\t${3:// body}",
      "end"
    ],
    "description": "حلقة for"
  },

  "While Loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition}:",
      "\t${2:// body}",
      "end"
    ],
    "description": "حلقة while"
  },

  "Do-While Loop": {
    "prefix": "dowhile",
    "body": [
      "do:",
      "\t${1:// body}",
      "while(${2:condition})"
    ],
    "description": "حلقة do-while (تنفذ مرة على الأقل)"
  },

  "Try Catch Finally": {
    "prefix": "try",
    "body": [
      "try:",
      "\t${1:// code}",
      "catch (${2:err}):",
      "\t${3:// handle error}",
      "finally:",
      "\t${4:// cleanup}",
      "end"
    ],
    "description": "try catch finally"
  },

  "Variable (let)": {
    "prefix": "let",
    "body": [
      "let ${1:name} = ${2:value}"
    ],
    "description": "تعريف متغير ثابت في النطاق"
  },

  "Variable (var)": {
    "prefix": "var",
    "body": [
      "var ${1:name} = ${2:value}"
    ],
    "description": "تعريف متغير (مرادف لـ let)"
  },

  "Import": {
    "prefix": "imp",
    "body": [
      "import ${1:math}"
    ],
    "description": "استيراد وحدة من المكتبة القياسية"
  },

  "Import As": {
    "prefix": "impa",
    "body": [
      "import ${1:math} as ${2:alias}"
    ],
    "description": "استيراد وحدة مع اسم مستعار"
  },

  "JSON Serialize": {
    "prefix": "jsons",
    "body": [
      "import json",
      "print(json.serialize(${1:data}))"
    ],
    "description": "تحويل البيانات إلى JSON"
  },

  "Random Int": {
    "prefix": "randint",
    "body": [
      "import random",
      "let ${1:num} = random.int(${2:1}, ${3:100})"
    ],
    "description": "توليد رقم عشوائي صحيح"
  },

  "Lang Version": {
    "prefix": "langv",
    "body": [
      "import lang",
      "print(\"Djazair Version: \" + lang.version())"
    ],
    "description": "عرض إصدار اللغة"
  },

  "Print": {
    "prefix": "pr",
    "body": [
      "print(${1:value});"
    ],
    "description": "طباعة قيمة"
  },

  "Main Function": {
    "prefix": "main",
    "body": [
      "fn main():",
      "\t${1:// main code}",
      "end"
    ],
    "description": "الدالة الرئيسية"
  }
}