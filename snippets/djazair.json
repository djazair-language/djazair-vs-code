{
  "Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:args})",
      "\t${3:// body}",
      "end"
    ],
    "description": "Create a new function"
  },
  
  "Arrow Function": {
    "prefix": "af",
    "body": [
      "fn(${1:args}) => ${2:expression}"
    ],
    "description": "Arrow function"
  },

  "Class": {
    "prefix": "class",
    "body": [
      "class ${1:ClassName}",
      "\tinit(${2:args})",
      "\t\tself.${3:property} = ${4:value}",
      "\tend",
      "",
      "\t${5:method}(${6:args})",
      "\t\t${7:// method body}",
      "\tend",
      "end"
    ],
    "description": "Create a new class"
  },

  "If Statement": {
    "prefix": "if",
    "body": [
      "if ${1:condition}",
      "\t${2:// code}",
      "end"
    ],
    "description": "Simple if statement"
  },

  "If Else": {
    "prefix": "ife",
    "body": [
      "if ${1:condition}",
      "\t${2:// code}",
      "else",
      "\t${3:// code}",
      "end"
    ],
    "description": "if else"
  },

  "If Elif Else": {
    "prefix": "ifel",
    "body": [
      "if ${1:condition}",
      "\t${2:// code}",
      "elif ${3:condition}",
      "\t${4:// code}",
      "else",
      "\t${5:// code}",
      "end"
    ],
    "description": "Full if elif else chain"
  },

  "Match Case": {
    "prefix": "match",
    "body": [
      "match ${1:value}",
      "\tcase ${2:pattern1}",
      "\t\t${3:// code}",
      "\tcase ${4:pattern2}",
      "\t\t${5:// code}",
      "\tdefault",
      "\t\t${6:// default code}",
      "end"
    ],
    "description": "Match case statement"
  },

  "For Loop": {
    "prefix": "for",
    "body": [
      "for ${1:item} in ${2:iterable}",
      "\t${3:// body}",
      "end"
    ],
    "description": "For loop"
  },

  "While Loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition}",
      "\t${2:// body}",
      "end"
    ],
    "description": "While loop"
  },

  "Do-While Loop": {
    "prefix": "dowhile",
    "body": [
      "do",
      "\t${1:// body}",
      "while ${2:expression}"
    ],
    "description": "Do-while loop (executes at least once)"
  },

  "Try Catch Finally": {
    "prefix": "try",
    "body": [
      "try",
      "\t${1:// code}",
      "catch ${2:err}",
      "\t${3:// handle error}",
      "finally",
      "\t${4:// cleanup}",
      "end"
    ],
    "description": "Try catch finally"
  },

  "Variable (let)": {
    "prefix": "let",
    "body": [
      "let ${1:name} = ${2:value}"
    ],
    "description": "Define a block-scoped variable"
  },

  "Import": {
    "prefix": "imp",
    "body": [
      "use ${1:library}"
    ],
    "description": "Import a library"
  },

  "Import As": {
    "prefix": "impa",
    "body": [
      "use ${1:library} as ${2:alias}"
    ],
    "description": "Import a library with an alias"
  },

  "Import As Star": {
    "prefix": "imps",
    "body": [
      "use ${1:library} as *"
    ],
    "description": "Import all symbols from a library"
  },

  "Import File": {
    "prefix": "imf",
    "body": [
      "import \"${1:file.dz}\""
    ],
    "description": "Import a local file"
  },

  "Print": {
    "prefix": "pr",
    "body": [
      "print(${1:value})"
    ],
    "description": "Print a value"
  }
}